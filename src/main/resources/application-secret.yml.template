spring:
  datasource:
    # DB 연결 정보 (Docker Compose의 db 컨테이너명 혹은 외부 IP)
    url: jdbc:postgresql://${DB_HOST:db}:${DB_PORT:5432}/${POSTGRES_DB:extension_blocker}
    username: ${POSTGRES_USER:admin}
    password: ${POSTGRES_PASSWORD:your_secure_password}

# (선택) 외부 스토리지나 추가 연동이 생길 경우 이곳에 Secret을 추가합니다.
cloud:
  gcp:
    project-id: ${GCP_PROJECT_ID:your-gcp-project-id}
    credentials:
      location: ${GCP_CREDENTIALS_PATH:/path/to/key.json}
